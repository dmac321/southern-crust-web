# ── Square environment ──────────────────────────────────────────────────────
# Set to "sandbox" for testing, "production" for live payments.
# Must match the credentials below — mixing environments causes auth errors.
VITE_SQUARE_ENV=sandbox

# ── Square Web Payments SDK (browser — safe to expose) ──────────────────────
# Found in: Square Developer Dashboard → [App] → Credentials tab
# Production Application ID format:  sq0idp-XXXXXXXXXXXXXXXXXXXXXXXX
# Sandbox Application ID format:     sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXXXX
VITE_SQUARE_APP_ID=sandbox-sq0idb-your_app_id_here

# Location ID format (same pattern for both environments): LXXXXXXXXXXXXXXXXXX
VITE_SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXXX

# ── Square API (server-side only — NEVER commit real values) ─────────────────
# Must match VITE_SQUARE_ENV above
SQUARE_ENV=sandbox

# Found in: Square Developer Dashboard → [App] → Credentials tab
# Production Access Token starts with: EAAAl...
# Sandbox Access Token starts with:    EAAAl... (same pattern, different value)
SQUARE_ACCESS_TOKEN=EAAAl_your_access_token_here

# Same Location ID as above
SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXXX
